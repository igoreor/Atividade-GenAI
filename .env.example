# Copie este arquivo para .env e preencha com sua chave
GOOGLE_API_KEY=sua_chave_aqui

# Modelo Gemini a usar (padrão: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Caminho do banco SQLite (relativo à raiz do projeto)
DB_PATH=banco.db

# Limite máximo de linhas retornadas por consulta livre
MAX_ROWS=500
